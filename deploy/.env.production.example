# ────────────────────────────────────────────────────────────
# Production .env template — copy to /home/ubuntu/padlok-api/.env on the box.
# Generate JWT_SECRET fresh: `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
# ────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1
# Comma-separated list of allowed origins. Include the Amplify default URL
# AND any custom domain you set up later (e.g. admin.padlokit.com).
CORS_ORIGIN=https://main.d37bpt4nx3d74t.amplifyapp.com,https://admin.padlokit.com

# Supabase pooler — port 6543, ?pgbouncer=true is required so we use the
# transaction pooler instead of the session pooler. Get this URL from the
# Supabase project Settings → Database → Connection pooling → Transaction.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true
DB_SSL=true
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000

# Upstash Redis (free tier).
# Use the `rediss://...` (TLS) URL from the Upstash console — NOT the rest URL.
REDIS_URL=rediss://default:PASSWORD@HOST.upstash.io:6379

# Generate fresh; do NOT reuse the dev secret. Run on the box:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_ME_64_HEX_BYTES
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Brevo API key from the Brevo dashboard (SMTP & API → API keys).
# DO NOT commit a real key — paste it directly into the EC2 .env on the box.
BREVO_API_KEY=xkeysib-REPLACE_ME
BREVO_SENDER_EMAIL=no-reply@padlokit.com
BREVO_SENDER_NAME=PadLok Admin

# Used inside invitation emails so the link points at production.
DASHBOARD_URL=https://admin.padlokit.com
