# ────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173

# ────────────────────────────────────────────────────────────
# Database (shared with padlokbackend)
# ────────────────────────────────────────────────────────────
# Option A — single URL
DATABASE_URL=postgres://user:password@localhost:5432/padlok
# Option B — discrete
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=padlok
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_SSL=false
DB_POOL_MAX=40
DB_IDLE_TIMEOUT_MS=30000

# ────────────────────────────────────────────────────────────
# Redis
# ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────
# JWT — admin tokens (separate secret from client backend)
# ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# ────────────────────────────────────────────────────────────
# Rate limiting
# ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ────────────────────────────────────────────────────────────
# Email (Brevo) — used for admin invitations
# ────────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@padlok.com
BREVO_SENDER_NAME=PadLok Admin

# ────────────────────────────────────────────────────────────
# Dashboard URL (for invitation links)
# ────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5173
